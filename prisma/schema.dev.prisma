generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactRequest {
  id        String   @id @default(cuid())
  shop      String
  type      String
  subject   String
  message   String
  email     String?
  createdAt DateTime @default(now())

  @@index([shop, createdAt])
}

model JudgeMeConnection {
  id                String    @id @default(cuid())
  shop              String    @unique
  shopDomain        String
  authMethod        String
  encryptedApiToken String
  tokenMask         String
  scope             String?
  status            String    @default("connected")
  shopName          String?
  shopEmail         String?
  ownerName         String?
  plan              String?
  platform          String?
  country           String?
  timezone          String?
  widgetVersion     String?
  awesome           Boolean?
  reviewCount       Int?
  lastVerifiedAt    DateTime?
  lastError         String?
  accountJson       String?
  settingsJson      String?
  sampleReviewsJson String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([shop, status])
}

model ReviewDraft {
  id               String    @id @default(cuid())
  shop             String
  source           String    @default("judgeme")
  sourceReviewId   String
  sourceReviewJson String?
  customerName     String?
  customerInitials String?
  productTitle     String?
  productType      String?
  productTagsJson  String?
  reviewBody       String
  rating           Int?
  sourceCreatedAt  DateTime?
  draft            String
  confidence       Int
  aiModelId        String?
  aiModelName      String?
  aiProviderName   String?
  aiProviderModel  String?
  draftGeneratedAt DateTime?
  draftEditedAt    DateTime?
  draftRevisionCount Int     @default(0)
  humanRequired    Boolean   @default(false)
  status           String    @default("pending")
  sentAt           DateTime?
  skippedAt        DateTime?
  lastSyncedAt     DateTime  @default(now())
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([shop, source, sourceReviewId])
  @@index([shop, status, sourceCreatedAt])
}

model BrandVoiceSetting {
  id                String   @id @default(cuid())
  shop              String   @unique
  personality       String
  greeting          String
  signOff           String
  alwaysMentionJson String
  avoidPhrasesJson  String
  selectedModel     String
  livePreview       String?
  previewReview     String?
  previewProductId  String?
  previewProductTitle String?
  previewProductType String?
  previewProductTagsJson String?
  previewRating     Int      @default(5)
  personalityStyle  String   @default("balanced")
  personalityStrength String @default("balanced")
  replyLength       String   @default("medium")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AiProviderDailyState {
  id                  String   @id @default(cuid())
  provider            String
  dayKey              String
  currentModelId      String?
  exhaustedModelsJson String   @default("[]")
  lastErrorJson       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([provider, dayKey])
}

model AppSetting {
  id           String   @id @default(cuid())
  shop         String   @unique
  settingsJson String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CreditAccount {
  id               String   @id @default(cuid())
  shop             String   @unique
  startingCredits  Int      @default(100)
  purchasedCredits Int      @default(0)
  bonusCredits     Int      @default(0)
  spentCredits     Int      @default(0)
  refundedCredits  Int      @default(0)
  balance          Int      @default(100)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CreditLedgerEntry {
  id            String   @id @default(cuid())
  shop          String
  type          String
  amount        Int
  balanceAfter  Int
  description   String
  referenceType String?
  referenceId   String?
  metadataJson  String?
  createdAt     DateTime @default(now())

  @@index([shop, createdAt])
  @@index([shop, referenceType, referenceId])
}

model CreditPurchase {
  id                String   @id @default(cuid())
  shop              String
  packageId         String
  credits           Int
  amountCents       Int
  currencyCode      String   @default("USD")
  status            String   @default("pending")
  shopifyPurchaseId String?  @unique
  confirmationUrl   String?
  lastError         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt])
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}
