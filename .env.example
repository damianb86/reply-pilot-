COMPOSE_PROJECT_NAME=igu
SHARED_DOCKER_NETWORK=shared_apps
APP_ENV=development

APP_HOST=igu.tudominio.com
SHOPIFY_APP_URL=
PROD_SHOPIFY_APP_URL=https://igu.tudominio.com
DEV_SHOPIFY_APP_URL=
SHOPIFY_API_KEY=replace-with-shopify-client-id
SHOPIFY_API_SECRET=replace-with-shopify-client-secret
SHOPIFY_BILLING_TEST=true
SCOPES=read_products

APP_DB_NAME=igu
APP_DB_USER=igu
APP_DB_PASSWORD=replace-with-app-db-password
DEV_DATABASE_URL=file:./dev.sqlite
DATABASE_URL=postgresql://igu:replace-with-app-db-password@postgres:5432/igu?schema=public&connection_limit=3

CONTACT_EMAIL=damianbe86@gmail.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=smtp-user@example.com
EMAIL_PASS=replace-with-smtp-password

JUDGEME_TOKEN_ENCRYPTION_KEY=

OPENAI_API_KEY=
OPENAI_BASIC_MODEL=gpt-5.4-nano
OPENAI_PRO_MODEL=gpt-5.4-mini
OPENAI_PREMIUM_MODEL=gpt-5.4
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

NODE_OPTIONS=--max-old-space-size=128
