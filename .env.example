COMPOSE_PROJECT_NAME=reply-pilot
SHARED_DOCKER_NETWORK=shared_apps
APP_ENV=production

APP_HOST=qorve-3.duckdns.org
SHOPIFY_APP_URL=
PROD_SHOPIFY_APP_URL=https://qorve-3.duckdns.org
DEV_SHOPIFY_APP_URL=
SHOPIFY_API_KEY=replace-with-shopify-client-id
SHOPIFY_API_SECRET=replace-with-shopify-client-secret
SHOPIFY_BILLING_TEST=false
SCOPES=read_products

APP_DB_NAME=reply_pilot
APP_DB_USER=reply_pilot
APP_DB_PASSWORD=replace-with-app-db-password
DEV_DATABASE_URL=file:./dev.sqlite
DATABASE_URL=postgresql://reply_pilot:replace-with-app-db-password@postgres:5432/reply_pilot?schema=public&connection_limit=3

CONTACT_EMAIL=contact@example.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=smtp-user@example.com
EMAIL_PASS=replace-with-smtp-password

JUDGEME_TOKEN_ENCRYPTION_KEY=
JUDGEME_API_BASE_URL=https://judge.me/api/v1
JUDGEME_API_TIMEOUT_MS=10000
JUDGEME_TEST_DOMAIN_FIELD_ENABLED=false

OPENAI_API_KEY=replace-with-openai-api-key
AI_API_TIMEOUT_MS=45000
PRODUCT_DESCRIPTION_CREDIT_MULTIPLIER=1
OPENAI_BASIC_MODEL=gpt-5.4-nano
OPENAI_PRO_MODEL=gpt-5.4-mini
OPENAI_PREMIUM_MODEL=gpt-5.4
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

NODE_OPTIONS=--max-old-space-size=256
